GEO-ANALYSIS.md
docs/
*.md

# Editor / IDE
.vscode
.idea
*.swp
*.swo

# OS artefacts
.DS_Store
Thumbs.db

# Test / lint caches
.eslintcache
coverage/
vitest.config.ts

# TypeScript build info
tsconfig.tsbuildinfo
