{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "//": "include scoped during migration — Vite-coupled files (supabase/import.meta, contexts, hooks, api, router pages, old entry) widen to all of src in Phase 6.",
  "include": [
    "next-env.d.ts",
    "src/app/**/*",
    "src/components/ui/**/*",
    "src/domain/**/*",
    "src/i18n/**/*",
    "src/types/**/*",
    "src/lib/utils.ts",
    "src/lib/format.ts",
    "src/lib/date.ts",
    "src/lib/base64.ts",
    "src/lib/clipboard.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
