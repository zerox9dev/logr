# =============================================================================
# logr — Self-host environment variables
# Copy this file to .env and fill in real values before running docker compose.
#
# HOW TO GENERATE KEYS (easy path)
# --------------------------------
#   cp .env.example .env
#   node scripts/gen-env-keys.mjs >> .env   # appends real secrets; last value wins
#
# That fills POSTGRES_PASSWORD, JWT_SECRET, ANON_KEY and SERVICE_ROLE_KEY with a
# matched set (the keys are JWTs signed with the generated JWT_SECRET).
#
# Manual alternative: JWT_SECRET = `openssl rand -base64 40`; ANON_KEY and
# SERVICE_ROLE_KEY are JWTs signed with it — see
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# =============================================================================

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change_me_strong_password_here

# ---------------------------------------------------------------------------
# Supabase / JWT
# ---------------------------------------------------------------------------

# 32+ character random secret — used to sign all JWTs
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Anon key — JWT payload: { "role": "anon", "iss": "supabase", "iat": ..., "exp": ... }
# Signed with JWT_SECRET. Used by browser clients.
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjE4NTc3NjAwMDB9.REPLACE_ME

# Service role key — JWT payload: { "role": "service_role", ... }
# Signed with JWT_SECRET. NEVER expose this to the browser — server-only.
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MTg1Nzc2MDAwMH0.REPLACE_ME

# ---------------------------------------------------------------------------
# App — Next.js
# ---------------------------------------------------------------------------

# URL of the Kong API gateway (browser-reachable).
# This is what BOTH the browser AND the Next.js server use to reach Supabase.
# For local self-hosting this is http://localhost:8000.
# For a remote server replace with http://<your-server-ip>:8000 or a domain.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Same as ANON_KEY — duplicated here under the name Next.js expects
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# Same as SERVICE_ROLE_KEY — server-only, never sent to the browser
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# ---------------------------------------------------------------------------
# GoTrue (auth)
# ---------------------------------------------------------------------------

# The URL end-users land on (your app, not Kong). Used for auth redirect URLs.
SITE_URL=http://localhost:3000

# Comma-separated list of allowed post-auth redirect URLs
GOTRUE_URI_ALLOW_LIST=http://localhost:3000/**

# SMTP — optional. Required for real email delivery (magic links, invitations).
# If MAILER_AUTOCONFIRM=true, GoTrue auto-confirms new sign-ups without email.
# For production you MUST set SMTP_* and set MAILER_AUTOCONFIRM=false.
MAILER_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@localhost

# ---------------------------------------------------------------------------
# Optional — GoTrue operator token (leave blank unless you know why you need it)
# ---------------------------------------------------------------------------
OPERATOR_TOKEN=
