# =============================================================================
# logr — environment variables
# Copy to .env and fill in the values from your Supabase project.
#   cp .env.example .env
# =============================================================================

# Your Supabase project URL.
#   Cloud:      https://<project-ref>.supabase.co   (Project Settings → API)
#   Self-host:  http://<your-server>:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — Project Settings → API → "anon public".
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service_role (secret) key — Project Settings → API → "service_role".
# Server-only — powers the MCP endpoint. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Anthropic API key — server-only. Powers the in-app AI assistant (chat) and
# sharpens project suggestions. Without it, suggestions fall back to local
# history and the assistant is disabled. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Host port for the app container (default 3000). Change if 3000 is in use.
APP_PORT=3000

# Only needed if the app container reaches Supabase at a different URL than the
# browser does (e.g. you self-host Supabase on the same Docker network). Leave
# blank for Supabase Cloud.
SUPABASE_INTERNAL_URL=
