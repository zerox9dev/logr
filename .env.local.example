NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# server-only (do not prefix with NEXT_PUBLIC):
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Public app URL — used by the MCP OAuth metadata endpoints.
# Defaults to https://logr.work when unset. Set this for local dev or staging.
NEXT_PUBLIC_APP_URL=https://logr.work
# Optional, server-only — enables the in-app AI assistant + LLM project suggestions.
ANTHROPIC_API_KEY=
